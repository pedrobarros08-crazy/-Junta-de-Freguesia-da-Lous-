# Configuração da Base de Dados SQL Server
# Copie este ficheiro para .env e edite com as suas credenciais reais

DB_SERVER=SEU_SERVIDOR\SQLEXPRESS
DB_NAME=ACCESS APLICAÇÃO
DB_USER=Aplicação User
DB_PASSWORD=JFLousan#2026
DB_CHARSET=UTF-8

# Ambiente da aplicação (production|development)
APP_ENV=production

# Autenticação da aplicação
APP_USER=admin
APP_USER_ID=1
# Preferencial: usar hash gerado com password_hash()
APP_PASSWORD_HASH=
# Alternativa (apenas em desenvolvimento)
APP_PASSWORD=alterar_esta_password
